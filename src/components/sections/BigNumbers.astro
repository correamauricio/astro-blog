  <div class="flex gap-4 lg:min-w-[120vw] md:min-w-[200vw] min-w-[360vw]">
    
    <div 
      class="rounded-4xl grow bg-fixed bg-cover bg-center p-4"
      style={bgStyle}
    ></div>

    <div 
      class="rounded-4xl grow basis-0 col-span-2 bg-fixed bg-cover bg-center p-4"
      style={bgStyle}
    ></div>

    <div 
      class="rounded-4xl grow basis-0 col-span-2 bg-fixed bg-cover bg-center p-4"
      style={bgStyle}
    ></div>

    <div class="rounded-4xl grow basis-0 col-span-2 p-4 min-h-32 justify-center flex flex-col whitespace-nowrap">
      <h1 class="text-md-on-surface type-display-small-emphasized">+150 Mil</h1>
      <span class="text-md-on-surface type-body-large">alunos impactados</span>
    </div>

    <div 
