      class="rounded-4xl grow basis-0 col-span-2 bg-fixed bg-cover bg-center p-4"
      style={bgStyle}
    ></div>

    <div 
      class="rounded-4xl grow basis-0 col-span-2 bg-fixed bg-cover bg-center p-4"
      style={bgStyle}
    ></div>

