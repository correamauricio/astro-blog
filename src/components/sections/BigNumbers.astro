---
import { getImage } from 'astro:assets';
// Importe sua imagem original
import amanhecerSrc from '../../assets/BigNumbersBg.png';

// 1. Otimiza a imagem antes de renderizar (converte para webp, redimensiona se precisar)
const optimizedBg = await getImage({
  src: amanhecerSrc,
  format: 'webp',
  quality: 'high',
});

// Criamos uma string auxiliar para limpar o HTML
const bgStyle = `background-image: url(${optimizedBg.src});`;
