---
import { getImage } from 'astro:assets';
import bgImage from '../../assets/BigNumbersImage.png';

const optimizedBg = await getImage({
  src: bgImage,
  format: 'webp',
});

const bgStyle = `background-image: url(${optimizedBg.src});`;
